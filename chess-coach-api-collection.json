                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Mate in 2\",\n  \"type\": \"BOARD\",\n  \"dueDate\": \"2026-04-10T23:59:59Z\",\n  \"imageUrls\": [\n    \"https://res.cloudinary.com/dtqkltvop/image/upload/v1/homeworks/board1.jpg\"\n  ],\n  \"challenge\": {\n    \"fen\": \"r1bqkbnr/pppp1ppp/2n5/4p3/2B1P3/5Q2/PPPP1PPP/RNB1K1NR w KQkq - 0 1\",\n    \"winningMoves\": [\n      \"Qxf7#\"\n    ]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/classrooms/{{classroomId}}/homework",
              "host": ["{{baseUrl}}"],
              "path": ["api", "classrooms", "{{classroomId}}", "homework"]
