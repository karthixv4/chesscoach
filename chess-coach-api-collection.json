              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"COMPLETED\",\n  \"notes\": \"Good session\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/classrooms/{{classroomId}}/sessions/{{sessionId}}/status",
              "host": [
