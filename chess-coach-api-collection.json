              "raw": "{\n  \"date\": \"2026-04-01\",\n  \"startTime\": \"2026-04-01T10:00:00Z\",\n  \"endTime\": \"2026-04-01T11:00:00Z\",\n  \"title\": \"Opening Principles\",\n  \"link\": \"https://meet.google.com/xyz\",\n  \"notes\": \"Review previous homework before starting\"\n}"
            },
            "url": {
